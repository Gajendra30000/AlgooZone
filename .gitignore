# Root Level .gitignore

# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment variables (SENSITIVE - NEVER COMMIT)
.env
.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDE files
.vscode/
.idea/
*.iml
*.iws
*.ipr
.sublime-workspace
.sublime-project

# Build outputs
dist/
build/
.next/

# Logs
logs/
*.log
npm-debug.log*

# Testing
coverage/
.nyc_output/

# Temporary files
.cache/
*.tmp
*.temp

# API Keys and Secrets
*.pem
*.key
*.pub

# Lock files (use npm ci instead)
package-lock.json
yarn.lock
pnpm-lock.yaml
